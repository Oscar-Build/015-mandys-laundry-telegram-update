{
  "name": "mandys-laundry-automation",
  "version": "1.0.0",
  "description": "SEO automation system for Mandy's Laundry with Telegram notifications, health monitoring, and auto-publishing",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js --ignore logs/ --ignore data/",
    "test": "jest --coverage",
    "daily-summary": "node -e \"require('./src/scheduler/jobs/dailySummary').run()\"",
    "health-check": "node -e \"require('./src/scheduler/jobs/healthCheck').run()\"",
    "smoke-test": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "simple-git": "^3.27.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
