# ============================================================
# Mandy's Laundry Automation - Environment Configuration
# Copy this file to .env and fill in all values
# ============================================================

# --- Application ---
NODE_ENV=production
APP_NAME=Mandys Laundry Automation
LOG_LEVEL=info
PORT=3000

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Oscar Team notification group chat ID
TELEGRAM_CHAT_ID=-5572635670
# Set to true to send a startup notification when the system boots
TELEGRAM_NOTIFY_ON_START=true

# --- Website / CMS ---
# WordPress REST API base URL (e.g. https://mandyslaundry.com/wp-json/wp/v2)
WORDPRESS_API_URL=https://mandyslaundry.com/wp-json/wp/v2
WORDPRESS_USERNAME=your_wordpress_username_here
WORDPRESS_APP_PASSWORD=your_wordpress_app_password_here

# --- Content Generation (Anthropic Claude) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model to use for content generation
CONTENT_MODEL=claude-haiku-4-5-20251001
# How many pages to generate per scheduled run
PAGES_PER_RUN=10
# Niche/topic for content (used in prompts)
CONTENT_NICHE=laundry services, dry cleaning, fabric care

# --- Google Indexing API (OAuth 2.0) ---
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
# Run once: node -r dotenv/config scripts/google-auth.js  — then paste the token here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
# Your website URL registered in Google Search Console
SITE_URL=https://mandyslaundry.com

# --- Database ---
# Path to the SQLite database file
DB_PATH=./data/automation.db

# --- Git Auto-Push ---
GIT_AUTO_PUSH=true
GIT_REMOTE=origin
GIT_BRANCH=main
# Your git user identity (used for auto-commits)
GIT_USER_NAME=Oscar Automation
GIT_USER_EMAIL=automation@mandyslaundry.com

# --- Scheduling ---
# Daily summary cron: every day at 8:00 AM
DAILY_SUMMARY_CRON=0 8 * * *
# Health check cron: every 5 minutes
HEALTH_CHECK_CRON=*/5 * * * *
# Content generation cron: every day at 6:00 AM
CONTENT_GEN_CRON=0 6 * * *

# --- Retry Configuration ---
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=5000

# --- Health Monitor ---
# Seconds before an unresponsive service triggers a Telegram alert
HEALTH_ALERT_THRESHOLD_SECONDS=300
