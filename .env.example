# ============================================================
# Mandy's Laundry Automation — Environment Configuration
# Copy this file to .env and fill in all values
# ============================================================

# --- Application ---
NODE_ENV=production
APP_NAME=Mandys Laundry Automation
LOG_LEVEL=info
PORT=3000

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=-5572635670
TELEGRAM_NOTIFY_ON_START=true

# --- Website / CMS ---
WORDPRESS_API_URL=https://mandyslaundry.com/wp-json/wp/v2
WORDPRESS_SITE_URL=https://mandyslaundry.com
WORDPRESS_USERNAME=your_wordpress_username_here
WORDPRESS_APP_PASSWORD=your_wordpress_app_password_here

# --- Content Generation (Anthropic Claude) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CONTENT_MODEL=claude-haiku-4-5-20251001
PAGES_PER_RUN=10
LANDING_PAGES_PER_RUN=3
CONTENT_NICHE=laundry services, dry cleaning, fabric care

# --- Google APIs (OAuth 2.0 — shared for Indexing + Search Console + Analytics) ---
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
# Run once: node -r dotenv/config scripts/google-auth.js  — then paste token here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
# Your website registered in Google Search Console
SITE_URL=https://mandyslaundry.com

# --- Google Analytics 4 ---
# From GA4 → Admin → Property → Property Details
GOOGLE_GA4_PROPERTY_ID=123456789
# Optional: PageSpeed Insights API key (increases rate limits)
GOOGLE_PAGESPEED_API_KEY=your_pagespeed_api_key_here

# --- SEO Configuration ---
SEO_AUDIT_MAX_PAGES=50
SEO_THIN_CONTENT_WORDS=300
# Comma-separated list of target cities for landing pages
SEO_TARGET_CITIES=Los Angeles,San Diego,Anaheim,Long Beach,Santa Ana
# Comma-separated list of target services for landing pages
SEO_TARGET_SERVICES=laundry pickup,dry cleaning,wash and fold,commercial laundry
SEO_TARGET_STATE=CA

# --- Analytics Thresholds ---
# Alert when weekly traffic drops by this fraction (0.2 = 20%)
TRAFFIC_DROP_THRESHOLD=0.2
# Alert when weekly traffic spikes by this fraction (0.5 = 50%)
TRAFFIC_SPIKE_THRESHOLD=0.5

# --- Database ---
DB_PATH=./data/automation.db

# --- Git Auto-Push ---
GIT_AUTO_PUSH=true
GIT_REMOTE=origin
GIT_BRANCH=main
GIT_USER_NAME=Oscar Automation
GIT_USER_EMAIL=automation@mandyslaundry.com

# --- Cron Schedules (America/Los_Angeles timezone) ---
# Every 5 minutes: health check
HEALTH_CHECK_CRON=*/5 * * * *
# Every 10 minutes: queue + worker health
TEN_MINUTE_CHECK_CRON=*/10 * * * *
# Every hour: uptime + indexing retries
HOURLY_CHECK_CRON=0 * * * *
# Daily 6:00 AM: generate blog posts
CONTENT_GEN_CRON=0 6 * * *
# Daily 6:30 AM: generate local landing pages
LANDING_PAGE_GEN_CRON=30 6 * * *
# Daily 7:00 AM: sync GSC + GA4 + daily report
ANALYTICS_SYNC_CRON=0 7 * * *
# Daily 6:00 AM: send morning Telegram briefing
DAILY_SUMMARY_CRON=0 6 * * *
# Every Monday 3:00 AM: full site audit + weekly report
WEEKLY_AUDIT_CRON=0 3 * * 1

# --- Retry Configuration ---
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=5000

# --- Health Monitor ---
HEALTH_ALERT_THRESHOLD_SECONDS=300
